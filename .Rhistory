SD_Yield = sd(Yield, na.rm = TRUE),
.groups = 'drop'
)
print("--- Summary Statistics (Means and SD) ---")
print(as.data.frame(summary_stats))
# Optional: Write these stats to a CSV file
write.csv(summary_stats, "Summary_Stats_Yield.csv", row.names = FALSE)
# 5. RUN TWO-WAY ANOVA
# ------------------------------------------------------------------------------
# Model: Yield depends on Genotype, Location, and their Interaction (*)
anova_model <- aov(Yield ~ Genotype * Location, data = data)
print("--- ANOVA Table ---")
summary(anova_model)
# 6. POST-HOC TEST (Tukey HSD)
# ------------------------------------------------------------------------------
# Only useful if the ANOVA shows significant differences
tukey_result <- TukeyHSD(anova_model)
print("--- Tukey HSD Post-Hoc Test Results ---")
print(tukey_result)
# 7. PLOT
# ------------------------------------------------------------------------------
# Interaction Plot
interaction.plot(
x.factor = data$Location,
trace.factor = data$Genotype,
response = data$Yield,
fun = mean,
type = "b",
col = rainbow(length(unique(data$Genotype))),
pch = 19,
fixed = TRUE,
xlab = "Location",
ylab = "Mean Yield (t/ha)",
legend = TRUE
)
title("Interaction Plot: Yield by Genotype and Location")
