# 1. INSTALL AND LOAD PACKAGES
# ------------------------------------------------------------------------------
if (!require("dplyr")) install.packages("dplyr")
library(dplyr)
target_file <- "BTF PRE-NPT Data BTF 20 Nov 2025 .csv"
if (file.exists(target_file)) {
print(paste("Loading file:", target_file))
data <- read.csv(target_file, check.names = FALSE)
} else {
print("File not found automatically. Please select the CSV file manually.")
data <- read.csv(file.choose(), check.names = FALSE)
}
# 3. DATA CLEANING
# ------------------------------------------------------------------------------
# Rename 'yield t/ha' to 'Yield' for easier coding
# We use check.names=FALSE in read.csv, so spaces are preserved in column names
if ("yield t/ha" %in% colnames(data)) {
colnames(data)[colnames(data) == "yield t/ha"] <- "Yield"
print("Column 'yield t/ha' renamed to 'Yield'.")
} else {
warning("Could not find 'yield t/ha' column. Please check spelling.")
}
# Convert to Factors
data$Genotype <- as.factor(data$Genotype)
data$Location <- as.factor(data$Location)
data$Yield <- as.numeric(data$Yield) # Ensure yield is numeric
# 4. CALCULATE OVERALL MEAN (GRAND MEAN)
# ------------------------------------------------------------------------------
overall_mean <- mean(data$Yield, na.rm = TRUE)
print("=========================================")
print(paste("OVERALL MEAN YIELD (Grand Mean):", round(overall_mean, 4), "t/ha"))
print("=========================================")
# 5. CALCULATE MEAN PER LOCATION PER VARIETY
# ------------------------------------------------------------------------------
# This groups by both Genotype and Location to get specific means
interaction_means <- data %>%
group_by(Genotype, Location) %>%
summarise(
N = n(),
Mean_Yield = mean(Yield, na.rm = TRUE),
SD_Yield = sd(Yield, na.rm = TRUE),
.groups = 'drop'
)
print("--- Mean Yield per Genotype per Location ---")
print(as.data.frame(interaction_means))
# Mean per Genotype (Across all locations)
genotype_means <- data %>%
group_by(Genotype) %>%
summarise(Mean_Yield = mean(Yield, na.rm = TRUE))
# Mean per Location (Across all genotypes)
location_means <- data %>%
group_by(Location) %>%
summarise(Mean_Yield = mean(Yield, na.rm = TRUE))
# 7. EXPORT RESULTS
# ------------------------------------------------------------------------------
write.csv(interaction_means, "Means_Per_Location_Per_Variety.csv", row.names = FALSE)
print("Saved detailed means to: Means_Per_Location_Per_Variety.csv")
# 1. INSTALL AND LOAD PACKAGES
# ------------------------------------------------------------------------------
if (!require("dplyr")) install.packages("dplyr")
if (!require("readr")) install.packages("readr") # for parse_number if needed
library(dplyr)
# 2. LOAD DATA
# ------------------------------------------------------------------------------
target_file <- "BTF PRE-NPT Data BTF 20 Nov 2025 .csv"
if (file.exists(target_file)) {
print(paste("Loading file:", target_file))
data <- read.csv(target_file, check.names = FALSE, stringsAsFactors = FALSE)
} else {
print("File not found automatically. Please select the CSV file manually.")
data <- read.csv(file.choose(), check.names = FALSE, stringsAsFactors = FALSE)
}
# 3. DATA PRE-PROCESSING & CLEANING
# ------------------------------------------------------------------------------
# Define columns that are NOT traits (Factors)
factor_cols <- c("Genotype", "Location", "Rep")
# Identify Trait columns (everything else)
# We exclude the factor columns to find the traits
all_cols <- colnames(data)
trait_cols <- setdiff(all_cols, factor_cols)
print("--- Detected Traits for Analysis ---")
print(trait_cols)
# Ensure Factors are set correctly
data$Genotype <- as.factor(data$Genotype)
data$Location <- as.factor(data$Location)
if("Rep" %in% names(data)) data$Rep <- as.factor(data$Rep)
# Clean Trait Columns (Handle commas in numbers like "1,397")
# We loop through each trait column and force it to numeric
for (trait in trait_cols) {
if (is.character(data[[trait]])) {
# Remove commas and spaces, then convert to numeric
data[[trait]] <- as.numeric(gsub("[, ]", "", data[[trait]]))
}
}
# 4. ANALYSIS LOOP (MEANS & ANOVA)
# ------------------------------------------------------------------------------
# We will store the mean dataframes in a list to merge them later
list_of_means <- list()
# Initialize the base dataframe for merging with just the unique groups
master_summary <- unique(data[, c("Genotype", "Location")])
print("STARTING ANALYSIS LOOP...")
print("=========================================")
for (trait in trait_cols) {
cat("\n\nProcessing Trait:", trait, "\n")
cat("-----------------------------------------\n")
# A. OVERALL MEAN
grand_mean <- mean(data[[trait]], na.rm = TRUE)
cat("Overall Mean (Grand Mean):", round(grand_mean, 4), "\n")
# B. TWO-WAY ANOVA (Genotype * Location)
# We use as.formula to dynamically create the model
f <- as.formula(paste0("`", trait, "` ~ Genotype * Location"))
# Wrap in tryCatch to skip if data is missing/constant for a trait
tryCatch({
model <- aov(f, data = data)
print(summary(model))
}, error = function(e) {
cat("ANOVA failed for this trait (possibly insufficient data).\n")
})
# C. CALCULATE MEANS PER GENOTYPE PER LOCATION
# We create a temporary dataframe for this specific trait
temp_means <- data %>%
group_by(Genotype, Location) %>%
summarise(
Mean_Value = mean(.data[[trait]], na.rm = TRUE),
.groups = 'drop'
)
# Rename the 'Mean_Value' column to the specific trait name
# e.g., "Mean_yield t/ha"
new_col_name <- paste0("Mean_", trait)
colnames(temp_means)[3] <- new_col_name
# Add to our list for merging later
list_of_means[[trait]] <- temp_means
}
# 5. MERGE ALL MEANS INTO ONE DATAFRAME
# ------------------------------------------------------------------------------
# We use the 'Reduce' function to merge all dataframes in the list by Genotype and Location
print("\nMerging results into one table...")
final_summary <- Reduce(function(x, y) merge(x, y, by = c("Genotype", "Location"), all = TRUE), list_of_means)
# 6. EXPORT RESULTS
# ------------------------------------------------------------------------------
output_filename <- "All_Traits_Means_Summary.csv"
write.csv(final_summary, output_filename, row.names = FALSE)
print("=========================================")
print(paste("Analysis Complete!"))
print(paste("All means saved to:", output_filename))
print("Check the Console output above for ANOVA tables.")
# 1. INSTALL AND LOAD PACKAGES
# ------------------------------------------------------------------------------
if (!require("dplyr")) install.packages("dplyr")
if (!require("readr")) install.packages("readr")
library(dplyr)
# 2. LOAD DATA
# ------------------------------------------------------------------------------
target_file <- "BTF PRE-NPT Data BTF 20 Nov 2025 .csv"
if (file.exists(target_file)) {
print(paste("Loading file:", target_file))
data <- read.csv(target_file, check.names = FALSE, stringsAsFactors = FALSE)
} else {
print("File not found automatically. Please select the CSV file manually.")
data <- read.csv(file.choose(), check.names = FALSE, stringsAsFactors = FALSE)
}
# 3. DATA PRE-PROCESSING & CLEANING
# ------------------------------------------------------------------------------
factor_cols <- c("Genotype", "Location", "Rep")
all_cols <- colnames(data)
trait_cols <- setdiff(all_cols, factor_cols)
print("--- Detected Traits for Analysis ---")
print(trait_cols)
# Ensure Factors are set correctly
data$Genotype <- as.factor(data$Genotype)
data$Location <- as.factor(data$Location)
if("Rep" %in% names(data)) data$Rep <- as.factor(data$Rep)
# Clean Trait Columns
for (trait in trait_cols) {
if (is.character(data[[trait]])) {
data[[trait]] <- as.numeric(gsub("[, ]", "", data[[trait]]))
}
}
# 4. ANALYSIS LOOP (MEANS, SD & ANOVA)
# ------------------------------------------------------------------------------
list_of_means <- list()
list_of_anova <- list() # New list to store ANOVA tables
print("STARTING ANALYSIS LOOP...")
print("=========================================")
for (trait in trait_cols) {
cat("Processing Trait:", trait, "...\n")
# --- A. TWO-WAY ANOVA (Genotype * Location) ---
f <- as.formula(paste0("`", trait, "` ~ Genotype * Location"))
tryCatch({
model <- aov(f, data = data)
# Extract the ANOVA table
anova_table <- as.data.frame(summary(model)[[1]])
# Add identifying columns so we know which trait/row this belongs to
anova_table$Trait <- trait
anova_table$Source <- rownames(anova_table)
# Reorder columns to put Trait and Source first
anova_table <- anova_table[, c("Trait", "Source", "Df", "Sum Sq", "Mean Sq", "F value", "Pr(>F)")]
# Store in list
list_of_anova[[trait]] <- anova_table
}, error = function(e) {
cat("ANOVA failed for trait:", trait, "\n")
})
# --- B. CALCULATE MEANS AND SD PER GENOTYPE PER LOCATION ---
temp_stats <- data %>%
group_by(Genotype, Location) %>%
summarise(
Mean_Value = mean(.data[[trait]], na.rm = TRUE),
SD_Value = sd(.data[[trait]], na.rm = TRUE),
.groups = 'drop'
)
# Rename columns dynamically to include the trait name
# e.g., "Mean_Yield" and "SD_Yield"
colnames(temp_stats)[3] <- paste0("Mean_", trait)
colnames(temp_stats)[4] <- paste0("SD_", trait)
# Add to list for merging
list_of_means[[trait]] <- temp_stats
}
# 5. MERGE MEANS & SD INTO ONE DATAFRAME
# ------------------------------------------------------------------------------
print("\nMerging Mean/SD tables...")
final_summary <- Reduce(function(x, y) merge(x, y, by = c("Genotype", "Location"), all = TRUE), list_of_means)
# 6. MERGE ANOVA RESULTS INTO ONE DATAFRAME
# ------------------------------------------------------------------------------
print("Merging ANOVA tables...")
final_anova <- do.call(rbind, list_of_anova)
rownames(final_anova) <- NULL # Reset row names
# 7. EXPORT RESULTS
# ------------------------------------------------------------------------------
means_filename <- "All_Traits_Means_SD_Summary.csv"
anova_filename <- "All_Traits_ANOVA_Results.csv"
write.csv(final_summary, means_filename, row.names = FALSE)
write.csv(final_anova, anova_filename, row.names = FALSE)
print("=========================================")
print("Analysis Complete!")
print(paste("1. Means & SDs saved to:", means_filename))
print(paste("2. ANOVA Tables saved to:", anova_filename))
# 1. INSTALL AND LOAD PACKAGES
# ------------------------------------------------------------------------------
packages <- c("dplyr", "stringr", "tidyr")
new_packages <- packages[!(packages %in% installed.packages()[,"Package"])]
if(length(new_packages)) install.packages(new_packages)
library(dplyr)
library(stringr)
library(tidyr)
# 2. LOAD DATA
# ------------------------------------------------------------------------------
target_file <- "BTF 2024 DATA  18 Nov 2025 JL .csv"
if (file.exists(target_file)) {
print(paste("Loading file:", target_file))
data <- read.csv(target_file, check.names = FALSE, stringsAsFactors = FALSE)
} else {
print("Target file not found automatically. Please select the CSV file manually.")
data <- read.csv(file.choose(), check.names = FALSE, stringsAsFactors = FALSE)
}
# 3. DATA CLEANING & PREPARATION
# ------------------------------------------------------------------------------
print("Cleaning Data...")
# A. Clean Column Names (Remove special characters like =, (), / for easier formulas)
original_names <- colnames(data)
new_names <- original_names %>%
str_replace_all(" ", "_") %>%       # Replace spaces with underscores
str_replace_all("[=/,\\(\\)]", "") # Remove symbols =, /, (, )
colnames(data) <- new_names
print("Renamed Columns for Analysis:")
print(colnames(data))
# B. Identify the specific YIELD column and Clean it
# In your snippet, Yield was "YLD_0_CONT (Kg/ha)" -> became "YLD_0_CONT_Kgha"
# It contained values like " 8,380 " which need text cleaning
yield_col_name <- grep("YLD", colnames(data), value = TRUE)
if(length(yield_col_name) > 0) {
# Remove quotes, spaces, and commas, then convert to numeric
data[[yield_col_name]] <- as.numeric(gsub("[^0-9.]", "", data[[yield_col_name]]))
print(paste("Cleaned numerical formatting for:", yield_col_name))
}
# C. Define Factors and Variables
# Factors: REP, BLOCK_NO_CONT, DESIGNATION
factors <- c("REP", "BLOCK_NO_CONT", "DESIGNATION")
# Dependent Variables (The 13 analysis variables)
# We exclude the factors to find the response variables
dep_vars <- setdiff(colnames(data), factors)
# Convert Factors to explicit Factor types
data[factors] <- lapply(data[factors], as.factor)
# Ensure Dependent Variables are Numeric
data[dep_vars] <- lapply(data[dep_vars], function(x) as.numeric(as.character(x)))
# D. Remove Rows with Missing Data (MANOVA requires complete cases)
initial_rows <- nrow(data)
data_clean <- na.omit(data)
final_rows <- nrow(data_clean)
print(paste("Rows removed due to missing values:", initial_rows - final_rows))
print(paste("Final rows for analysis:", final_rows))
# 4. CALCULATE MEANS AND SD (Descriptive Statistics)
# ------------------------------------------------------------------------------
print("Calculating Means and Standard Deviations...")
# Group by DESIGNATION (Variety) to get specific performance
summary_table <- data_clean %>%
group_by(DESIGNATION) %>%
summarise(across(all_of(dep_vars),
list(Mean = ~mean(., na.rm = TRUE),
SD = ~sd(., na.rm = TRUE)),
.names = "{.col}_{.fn}"))
# Export Means and SD to CSV
write.csv(summary_table, "Means_SD_Summary.csv", row.names = FALSE)
print("Saved descriptive statistics to 'Means_SD_Summary.csv'")
print("Running MANOVA...")
# Create a matrix of the dependent variables
Y <- as.matrix(data_clean[, dep_vars])
# Run the MANOVA
# We use the 'Pillai' or 'Wilks' test statistic (Wilks is common)
manova_result <- manova(Y ~ REP + BLOCK_NO_CONT + DESIGNATION, data = data_clean)
# Capture results
manova_summary <- summary(manova_result, test = "Wilks")
manova_summary_pillai <- summary(manova_result, test = "Pillai")
# 6. EXPORT MANOVA RESULTS
# ------------------------------------------------------------------------------
output_file <- "MANOVA_Results.txt"
sink(output_file)
cat("==============================================================\n")
cat("              THREE-WAY MANOVA RESULTS                        \n")
cat("==============================================================\n\n")
cat("Factors Tested: REP, BLOCK_NO_CONT, DESIGNATION\n")
cat(paste("Variables Tested (", length(dep_vars), "): \n", sep=""))
cat(paste(dep_vars, collapse = ", "), "\n\n")
cat("--- WILKS' LAMBDA TEST (Most Common) ---\n")
print(manova_summary)
cat("\n\n--- PILLAI'S TRACE TEST (More Robust to Violations) ---\n")
print(manova_summary_pillai)
cat("\n\n==============================================================\n")
cat("              UNIVARIATE ANOVA (Breakdown per Variable)       \n")
cat("==============================================================\n")
cat("This shows how factors affect each variable individually:\n\n")
# This shows the ANOVA for each of the 13 variables separately
summary_aov <- summary.aov(manova_result)
print(summary_aov)
sink()
print(paste("Analysis Complete. Results saved to:", output_file))
print("Check 'MANOVA_Results.txt' for significance levels and 'Means_SD_Summary.csv' for data.")
